rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Public read — guests need to see wedding images and hear music
    match /{allPaths=**} {
      allow read: if true;
    }

    // Wedding file uploads — only authorized admins for the specific wedding
    // Uses Firestore cross-reference to verify adminIds or super admin role
    match /weddings/{slug}/{fileName} {
      function isWeddingAdmin() {
        return request.auth != null && (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'super'
          || request.auth.uid in firestore.get(/databases/(default)/documents/weddings/$(slug)).data.adminIds
        );
      }

      // Upload: authorized + content type + size validation
      // Images: max 10MB (client-side compression reduces DSLR photos to ~1-3MB)
      // Audio: max 15MB (no client-side compression)
      // Video: max 50MB (story background videos)
      allow create, update: if isWeddingAdmin()
        && ((request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
            || (request.resource.contentType.matches('audio/.*') && request.resource.size < 15 * 1024 * 1024)
            || (request.resource.contentType.matches('video/.*') && request.resource.size < 50 * 1024 * 1024));

      // Delete: authorized only (no content type/size needed)
      allow delete: if isWeddingAdmin();
    }
  }
}
