{
  "functions": {
    "api/ssr-meta.ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api|assets|images|fonts|musics|textures|src|index\\.html|robots\\.txt|sitemap\\.xml|favicon\\.ico|google[a-z0-9]*\\.html).*)",
      "destination": "/api/ssr-meta?slug=$1"
    }
  ]
}
