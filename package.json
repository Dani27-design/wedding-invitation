{
  "name": "wedding-dani-marini",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "loc:code": "find src -name '*.ts' -o -name '*.tsx' | grep -v test | xargs wc -l | sort -rn",
